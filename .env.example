# Copy this file to .env and fill in your own key. Never commit the real .env file.

# Required — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — override the model used by the backend proxy.
# See https://docs.claude.com for current model IDs.
ANTHROPIC_MODEL=claude-sonnet-5

# Optional — local dev server port (used by server.js only)
PORT=3000
